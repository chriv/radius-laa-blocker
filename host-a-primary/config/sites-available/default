server default {

    listen {
        type = auth
        ipaddr = *
        port = 0
    }

    listen {
        type = acct
        ipaddr = *
        port = 0
    }

    # -------------------------------------------------------------------
    # authorize: runs first for every Access-Request.
    # UniFi sends the client MAC in User-Name for MAB (MAC Auth Bypass).
    #
    # MAC format verification: UniFi may send the MAC as any of these:
    #   aabbccddeeff          (no separator, lowercase)
    #   AA:BB:CC:DD:EE:FF     (colon-separated, uppercase)
    #   aa-bb-cc-dd-ee-ff     (dash-separated, lowercase)
    #
    # The LAA (Locally Administered Address) bit is bit 1 of the first octet,
    # which maps to the SECOND character of any standard MAC string — so the
    # regex below is format-agnostic. If the second char is 2, 6, a, A, e,
    # or E, the LAA bit is set and the MAC is randomized.
    #
    # To verify the actual format UniFi sends: after first deployment, check
    # container logs (`docker logs <container>` or CapRover app logs) for the
    # User-Name value in incoming Access-Request packets.
    # -------------------------------------------------------------------

    authorize {

        if (User-Name =~ /^.[26aeAE]/) {
            update reply {
                Reply-Message := "Randomized MAC Rejected"
            }
            reject
        }

        # Universally administered MAC — allow it through.
        update control {
            Auth-Type := Accept
        }

    }

    authenticate {
        Auth-Type Accept {
            ok
        }
    }

    preacct {
    }

    accounting {
        ok
    }

    session {
    }

    post-auth {
        Post-Auth-Type REJECT {
        }
    }

}
