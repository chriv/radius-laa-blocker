# RADIUS client definition for the UniFi controller.
#
# Copy this file to clients.conf and set the secret before deploying.
# The secret must match what is configured in the UniFi RADIUS profile.
# Both hosts (Host A and Host B) must use the same secret.
#
# --- ipaddr note ---
# FreeRADIUS validates the source IP of every incoming packet against this
# definition and silently drops anything that doesn't match.
#
# When running under Docker (CapRover/Swarm), ALL requests arrive from the
# Docker bridge NAT gateway — the actual UniFi controller IP is never visible
# to the container. Using 0.0.0.0/0 is intentional and safe here:
#   - The shared secret provides the real authentication barrier.
#   - Restricting to a specific IP breaks silently if Docker changes its
#     bridge subnet or the container is rescheduled on a different node.
#
# --- require_message_authenticator ---
# UniFi firmware sends Message-Authenticator in Access-Request packets
# (BlastRADIUS mitigation). Setting this to yes tells FreeRADIUS to require
# it, silencing the startup warnings and enabling the protection.

client unifi {
    ipaddr                        = 0.0.0.0/0
    secret                        = CHANGE_ME_SHARED_SECRET
    shortname                     = unifi
    nas_type                      = other
    require_message_authenticator = yes
}
