# Compose deployment on aarch64 hosts.
# Builds a base image with freeradius installed and auth logging enabled.
# Config files are volume-mounted by docker-compose.yml — not copied here.
# Config path: /etc/freeradius/3.0/

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends freeradius freeradius-utils \
    && sed -i 's/auth = no/auth = yes/' /etc/freeradius/3.0/radiusd.conf \
    && rm -rf /var/lib/apt/lists/*

EXPOSE 1812/udp

# TODO: Replace syslog log driver approach with tee + nc for dual output:
#   freeradius -f & tail -F /var/log/freeradius/radius.log | tee >(nc -u $SYSLOG_HOST $SYSLOG_PORT)
# This would keep docker logs / CapRover UI working while still forwarding to syslog,
# and eliminate the build.sh conditional + docker-compose logging block entirely.
CMD ["sh", "-c", "freeradius -f & tail -F /var/log/freeradius/radius.log"]
