# Project-level defaults for all RADIUS_LAA_BLOCKER_* variables.
# Host-level hosts/<instance>/.env overrides these — only put overrides there.
# Never put secrets in this file.

RADIUS_LAA_BLOCKER_PORT=1812
RADIUS_LAA_BLOCKER_SYSLOG_HOST=
RADIUS_LAA_BLOCKER_SYSLOG_PORT=514
RADIUS_LAA_BLOCKER_DEPLOY_METHOD=compose
RADIUS_LAA_BLOCKER_TARGET_ARCH=auto

# CapRover (required when DEPLOY_METHOD=caprover)
RADIUS_LAA_BLOCKER_CAPROVER_APP=
RADIUS_LAA_BLOCKER_CAPROVER_URL=
RADIUS_LAA_BLOCKER_CAPROVER_TOKEN=

# Compose remote deployment (leave empty to deploy to local machine)
RADIUS_LAA_BLOCKER_SSH_HOST=
RADIUS_LAA_BLOCKER_REMOTE_PATH=
