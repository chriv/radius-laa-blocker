# host-1: Mac mini, Docker Compose, production
# Copy to .env and fill in before deploying. .env is gitignored.

RADIUS_LAA_BLOCKER_SECRET=CHANGE_ME
RADIUS_LAA_BLOCKER_PORT=1812
RADIUS_LAA_BLOCKER_DEPLOY_METHOD=compose

# SSH_HOST empty = deploy to local machine (no rsync/SSH needed)
RADIUS_LAA_BLOCKER_SSH_HOST=
RADIUS_LAA_BLOCKER_REMOTE_PATH=

# Optional syslog
RADIUS_LAA_BLOCKER_SYSLOG_HOST=
RADIUS_LAA_BLOCKER_SYSLOG_PORT=514
