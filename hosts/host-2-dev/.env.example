# host-2-dev: rasp5-1.rennerfamily.org, CapRover, development
# Copy to .env and fill in before deploying. .env is gitignored.
# Dev instance runs on port 18120 to coexist with production on 1812.

RADIUS_LAA_BLOCKER_SECRET=CHANGE_ME
RADIUS_LAA_BLOCKER_PORT=18120
RADIUS_LAA_BLOCKER_DEPLOY_METHOD=caprover
RADIUS_LAA_BLOCKER_CAPROVER_APP=radius-laa-blocker-dev
RADIUS_LAA_BLOCKER_CAPROVER_URL=https://captain.apps.sewerslide.com
RADIUS_LAA_BLOCKER_CAPROVER_TOKEN=CHANGE_ME

# Optional syslog
RADIUS_LAA_BLOCKER_SYSLOG_HOST=
RADIUS_LAA_BLOCKER_SYSLOG_PORT=514
