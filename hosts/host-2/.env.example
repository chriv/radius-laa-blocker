# Copy this file to .env and fill in values before deploying.
# .env is gitignored — never commit it.

# Required
RADIUS_LAA_BLOCKER_SECRET=CHANGE_ME

# Port the host exposes to the network (AP controller points here)
# Development instance uses a non-standard port to coexist with production.
RADIUS_LAA_BLOCKER_PORT=18120

# Deployment method: caprover | compose
RADIUS_LAA_BLOCKER_DEPLOY_METHOD=caprover

# CapRover settings (required when DEPLOY_METHOD=caprover)
RADIUS_LAA_BLOCKER_CAPROVER_APP=radius_laa_blocker_dev
RADIUS_LAA_BLOCKER_CAPROVER_URL=https://captain.your-domain.com
RADIUS_LAA_BLOCKER_CAPROVER_TOKEN=CHANGE_ME

# Optional: forward logs to a syslog server
RADIUS_LAA_BLOCKER_SYSLOG_HOST=
RADIUS_LAA_BLOCKER_SYSLOG_PORT=514
